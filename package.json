{
	"name": "obsidian-todo-plus",
	"version": "0.1.0",
	"description": "GTD-style TODO management for Obsidian. Tag-gated: only collects checkboxes with #todo/ tags.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "jest --config jest.config.cjs"
	},
	"keywords": ["obsidian", "todo", "gtd"],
	"license": "GPL-3.0-only",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@types/jest": "^29.5.0",
		"esbuild": "0.25.5",
		"jest": "^29.7.0",
		"ts-jest": "^29.1.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
